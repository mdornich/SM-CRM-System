# LLM — mock for plumbing; codex or anthropic for real transcript extraction
LLM_PROVIDER=mock            # mock | codex | anthropic
CODEX_MODEL=                 # optional, e.g. gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5  # optional; override when Anthropic rotates models

# Obsidian
OBSIDIAN_VAULT_PATH=./output/obsidian-vault
OBSIDIAN_MODE=plain          # plain | cairns (cairns is Phase 4)
STORE_RAW_TRANSCRIPTS=true   # false -> store hash + metadata + evidence only

# CRM
CRM_PROVIDER=mock            # mock | twenty
CRM_REVIEW_REQUIRED=true     # true -> sync-crm only pushes approved review items
TWENTY_API_URL=http://localhost:3002
TWENTY_API_KEY=

# Granola (Phase 3)
GRANOLA_API_KEY=

# Pipeline
TRANSCRIPTS_INBOX_DIR=./examples/transcripts
RI_DB_PATH=./output/relationship_intel.db
RI_MOCK_CRM_PATH=./output/mock_crm
DEFAULT_OWNER=James
STALL_THRESHOLD_DAYS=21
